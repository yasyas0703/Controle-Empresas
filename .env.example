# Template das variáveis de ambiente do controle-triar.
# Copie para .env.local (gitignorado) e preencha com os valores reais.
# NUNCA commite valores reais — .env*.local e .env.production ficam fora do git.

# ────────────────────────────────────────────────────────────
# Supabase
# ────────────────────────────────────────────────────────────
# URL do projeto (https://<id>.supabase.co). Pública — vai pro bundle do browser.
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima do Supabase (JWT, role: anon). Pública — vai pro bundle do browser.
# Acesso ao banco é controlado por RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (JWT, role: service_role). NUNCA expor no front.
# BYPASSA RLS — usar apenas em rotas /api/* e scripts server-side.
SUPABASE_SERVICE_ROLE_KEY=

# ────────────────────────────────────────────────────────────
# Google OAuth (Gmail para envio de guias)
# ────────────────────────────────────────────────────────────
# Client ID do OAuth criado no Google Cloud Console.
GOOGLE_CLIENT_ID=

# Client Secret do OAuth. NUNCA expor no front.
GOOGLE_CLIENT_SECRET=

# Callback URL configurado no GCP (ex: https://seu-dominio/api/auth/google/callback).
# Em dev, geralmente http://localhost:3000/api/auth/google/callback
GOOGLE_REDIRECT_URI=

# Chave de 32 bytes (hex, 64 chars) para criptografar refresh tokens do Gmail
# salvos no banco. Gerar com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ATENÇÃO: trocar essa chave invalida todos os refresh tokens existentes —
# usuárias precisam reconectar Gmail.
GMAIL_TOKEN_ENCRYPTION_KEY=

# ────────────────────────────────────────────────────────────
# Email SMTP (recuperação de senha, notificações do sistema)
# ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
# Use App Password do Gmail, NUNCA a senha real da conta.
# (Conta Google → Segurança → Verificação em 2 etapas → Senhas de app)
SMTP_PASS=
EMAIL_FROM=

# ────────────────────────────────────────────────────────────
# Push notifications (Web Push / VAPID)
# ────────────────────────────────────────────────────────────
# Par VAPID gerado com:
#   npx web-push generate-vapid-keys
# A pública vai pro browser; a privada é usada server-side para assinar pushes.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@exemplo.com

# ────────────────────────────────────────────────────────────
# Usuários especiais (não comitar UUIDs reais)
# ────────────────────────────────────────────────────────────
# UUID do desenvolvedor — conta com proteções extras (não pode ser editada
# por outros admins).
DEVELOPER_USER_ID=

# UUID do "ghost user" — invisível em listagens, executa envios automáticos
# (cron, auto-envio).
GHOST_USER_ID=

# ────────────────────────────────────────────────────────────
# Cron jobs (Vercel injeta automaticamente em produção)
# ────────────────────────────────────────────────────────────
# Token verificado pelas rotas /api/cron/* — Vercel envia como
# Authorization: Bearer ${CRON_SECRET}. Gerar com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ────────────────────────────────────────────────────────────
# Auto-envio de guias (daemon local que monitora T:/Fiscal)
# ────────────────────────────────────────────────────────────
# Token enviado pelo watcher local em X-Machine-Token. Gerar com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTO_ENVIO_TOKEN=

# ────────────────────────────────────────────────────────────
# SSO para o app de Tarefas
# ────────────────────────────────────────────────────────────
# Segredo HMAC compartilhado com o app de Tarefas para assinar tokens SSO.
SSO_SHARED_SECRET=

# URL do app de Tarefas (ex: https://tarefas.triarcontabilidade.com.br)
# Pública — usada no botão "Tarefas" do menu.
NEXT_PUBLIC_TAREFAS_URL=

# ────────────────────────────────────────────────────────────
# URL pública do próprio app (opcional)
# ────────────────────────────────────────────────────────────
# Usada para gerar links absolutos em emails (ex: pixel de track-open).
# Se ausente, o código tenta inferir do request.
NEXT_PUBLIC_APP_URL=
